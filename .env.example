# ============================================
# Docling Service Configuration (Remote Mode)
# ============================================

# Conversion Mode: "remote" or "local"
DOCLING_CONVERSION_MODE=remote

# Required for remote mode
DOCLING_SERVICE_URL=https://your-docling-serve-instance.hf.space
DOCLING_SERVICE_API_KEY=replace-with-your-key

# Service Client Settings
DOCLING_SERVICE_TIMEOUT=3600
DOCLING_SERVICE_MAX_RETRIES=3
DOCLING_FALLBACK_TO_LOCAL=false

# ============================================
# MCP Conversion Settings
# ============================================

# URLs are fetched by the remote Docling Serve instance.
# Existing local file paths are uploaded to the authenticated Docling Serve
# instance and do not require temporary public file hosting.
# include_images=false with image_export_mode=placeholder avoids embedding large
# image payloads. Formula enrichment is useful for scientific papers, but adds
# processing time.
DOCLING_MCP_KEEP_IMAGES=false
DOCLING_MCP_DO_OCR=false
DOCLING_MCP_FORCE_OCR=false
DOCLING_MCP_OCR_PRESET=auto
DOCLING_MCP_DO_TABLE_STRUCTURE=true
DOCLING_MCP_TABLE_MODE=fast
DOCLING_MCP_PDF_BACKEND=docling_parse
DOCLING_MCP_ABORT_ON_ERROR=false
DOCLING_MCP_INCLUDE_IMAGES=false
DOCLING_MCP_IMAGE_EXPORT_MODE=placeholder
DOCLING_MCP_DO_CODE_ENRICHMENT=false
DOCLING_MCP_DO_FORMULA_ENRICHMENT=true
DOCLING_MCP_DO_PICTURE_CLASSIFICATION=false
DOCLING_MCP_DO_PICTURE_DESCRIPTION=false

# If your installed Docling version accepts threaded_docling_parse, it may
# improve speed. Switch back to docling_parse if you observe extraction
# regressions. The pinned Docling version for this repository accepts:
# docling_parse, pypdfium2, dlparse_v1, dlparse_v2, dlparse_v4.

# ============================================
# Existing Settings
# ============================================

DOCLING_MCP_LI_OLLAMA_MODEL=granite3.2:latest
DOCLING_MCP_LI_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
DOCLING_MCP_LLS_URL=http://localhost:8321
